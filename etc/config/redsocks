config redsocks 'global'
	option enabled '0'
	option log_debug 'off'
	option log_info 'on'
	option log 'syslog:local7'
	option daemon '1'
	option redirector 'iptables'

config redsocks 'connection'
	option local_ip '0.0.0.0'
	option local_port '1337'
	option ip 'xx.xx.xx.xx'
	option port 'xxxx'
	option type 'socks5'
	option login ''
	option password ''
	option interface 'br-lan'
	list bypass_domain 'facebook.com'
	list bypass_domain 'messenger.com'
	list bypass_ip '172.16.50.7'
